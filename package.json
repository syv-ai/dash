{
  "name": "dash",
  "version": "0.7.8",
  "description": "Dash — Desktop app for Claude Code with git worktree management",
  "main": "dist/main/main/entry.js",
  "author": "mhenrichsen <mads@syv.ai>, nthomsencph <nicolai@syv.ai>, FabianScott <fabian@syv.ai>",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n main,renderer -c blue,green \"pnpm dev:main\" \"pnpm dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron dist/main/main/entry.js --dev",
    "dev:renderer": "vite",
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "package:mac": "pnpm build && electron-builder --mac",
    "package:linux": "pnpm build && electron-builder --linux",
    "type-check": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "drizzle:generate": "drizzle-kit generate",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.syv.dash",
    "productName": "Dash",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/@syv-ai/pixel-agents-watcher/**"
    ],
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "syv-ai",
      "repo": "dash",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.svg",
      "category": "Development",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "dependencies": {
    "@syv-ai/pixel-agents-watcher": "^1.3.0",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.32.0",
    "electron-log": "^5.1.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "posthog-node": "^5.28.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "react-resizable-panels": "^2.1.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "xterm": "^5.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
